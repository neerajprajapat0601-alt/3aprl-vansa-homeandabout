{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "VANVASI AYURVEDA" },
    { "type": "textarea", "id": "brand_desc", "label": "Description", "default": "Premium Ayurvedic wellness solutions crafted for Dubai's discerning clientele." },
    { "type": "text", "id": "address", "label": "Address", "default": "Bicholi Mardana, Indore - 452016 (M.P.)" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+917880091133" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@vanvasiayurveda.com" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Footer Menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "link_list", "id": "menu", "label": "Select Menu" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Custom Footer" }]
}
{% endschema %}

<footer class="custom-footer">
  <div class="footer-wrapper">

    <!-- Left Column -->
    <div class="footer-col">
      <h2>{{ section.settings.brand_name }}</h2>
      <p>{{ section.settings.brand_desc }}</p>

      <p>📍 {{ section.settings.address }}</p>
      <p>📞 {{ section.settings.phone }}</p>
      <p>✉️ {{ section.settings.email }}</p>

      <div class="social-icons">
        <a href="#">f</a>
        <a href="#">i</a>
        <a href="#">t</a>
        <a href="#">in</a>
      </div>
    </div>

    <!-- Dynamic Menus -->
    {% for block in section.blocks %}
      <div class="footer-col">
        <h3>{{ block.settings.title }}</h3>
        <ul>
          {% for link in linklists[block.settings.menu].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}

  </div>

  <div class="footer-bottom">
    <p>© {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.</p>
    <div>
      <a href="/pages/privacy-policy">Privacy Policy</a>
      <a href="/pages/terms">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
.custom-footer {
  background: #f5f5f5;
  padding: 50px 20px;
  font-family: sans-serif;
}

.footer-wrapper {
  display: flex;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}

.footer-col {
  flex: 1;
  min-width: 220px;
}

.footer-col h2 {
  color: #3f6b4f;
  font-weight: 700;
}

.footer-col h3 {
  margin-bottom: 10px;
}

.footer-col p {
  color: #555;
  font-size: 14px;
}

.footer-col ul {
  list-style: none;
  padding: 0;
}

.footer-col ul li {
  margin-bottom: 8px;
}

.footer-col ul li a {
  text-decoration: none;
  color: #333;
  font-size: 14px;
}

.social-icons a {
  display: inline-block;
  margin-right: 10px;
  background: #3f6b4f;
  color: #fff;
  width: 35px;
  height: 35px;
  text-align: center;
  line-height: 35px;
  border-radius: 50%;
}

.footer-bottom {
  margin-top: 30px;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  border-top: 1px solid #ddd;
  padding-top: 15px;
  font-size: 13px;
}

.footer-bottom a {
  margin-left: 15px;
  color: #333;
  text-decoration: none;
}

/* ✅ Mobile Responsive */
@media (max-width: 768px) {
  .footer-wrapper {
    flex-direction: column;
  }

  .footer-bottom {
    flex-direction: column;
    gap: 10px;
  }
}
</style>
