<div class="video-slider-section" id="section-{{ section.id }}">
  <div class="video-slider-header">
    <span class="sub-badge">{{ section.settings.subheading }}</span>
    <h2 class="slider-title">{{ section.settings.heading_main }}<br><span>{{ section.settings.heading_italic }}</span></h2>
  </div>

  <div class="video-grid-container">
    <div class="video-flex-wrapper" id="video-wrapper-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="video-card">
          <div class="video-element-wrapper">
            <video 
              class="card-video" 
              muted 
              loop 
              playsinline 
              poster="{{ block.settings.poster_image | img_url: '600x' }}">
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
            
            <div class="video-actions">
  <button class="action-btn heart-btn" onclick="toggleHeart(this)" aria-label="Like">
    <svg class="icon-heart" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.78-8.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
  </button>
  
  <button class="action-btn share-btn" onclick="shareProduct('{{ shop.url }}{{ block.settings.product_ref.url }}', '{{ block.settings.product_name }}')" aria-label="Share">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="2" x2="11" y2="13"></line>
      <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
    </svg>
  </button>
</div>
          </div>

          <div class="video-card-info">
            <div class="author-row">
               <img src="{{ block.settings.author_img | img_url: '40x40' }}" class="author-thumb">
               <span class="product-title">{{ block.settings.product_name }}</span>
            </div>
            <p class="product-desc">{{ block.settings.description }}</p>
            <span class="product-price">{{ block.settings.price }}</span>
            
            <form action="/cart/add" method="post" enctype="multipart/form-data">
              <input type="hidden" name="id" value="{{ block.settings.product_variant_id }}">
              <button type="submit" class="add-to-cart-btn">
                {% if block.settings.btn_text %}{{ block.settings.btn_text }}{% else %}Add to Bag{% endif %}
              </button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shoppable Video Slider",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "OUR SIGNATURE COLLECTION" },
    { "type": "text", "id": "heading_main", "label": "Main Heading", "default": "Crafted for Your" },
    { "type": "text", "id": "heading_italic", "label": "Italic Heading", "default": "Trusted Stories" }
  ],
  "blocks": [
    {
      "type": "video_product",
      "name": "Video Product",
      "settings": [
        { "type": "text", "id": "video_url", "label": "Direct MP4 Link (from Shopify Files)" },
        { "type": "image_picker", "id": "poster_image", "label": "Thumbnail Image" },
        { "type": "image_picker", "id": "author_img", "label": "Small Icon Image" },
        { "type": "text", "id": "product_name", "label": "Product Name" },
        { "type": "textarea", "id": "description", "label": "Short Description" },
        { "type": "text", "id": "price", "label": "Price (e.g. INR 549)" },
        { "type": "product", "id": "product_ref", "label": "Select Product" },
        { "type": "text", "id": "product_variant_id", "label": "Variant ID (for Add to Cart)" },
        { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Add to Bag" }
      ]
    }
  ],
  "presets": [ { "name": "Shoppable Video Slider" } ]
}
{% endschema %}

<style>
.video-actions {
  position: absolute;
  bottom: 20px;
  right: 15px;
  display: flex;
  flex-direction: row; /* Side by side like your screenshot */
  gap: 15px;
  z-index: 10;
}

.action-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: transform 0.2s ease;
}

.action-btn svg {
  filter: drop-shadow(0 1px 3px rgba(0,0,0,0.5));
}

/* Heart Active State */
.heart-btn.is-active svg {
  fill: #ff0000;
  stroke: #ff0000;
  transform: scale(1.2);
}

.action-btn:active {
  transform: scale(0.9);
}



.video-slider-section {
  padding: 60px 0;
  background: #fff;
  overflow: hidden;
}
.video-slider-header { text-align: center; margin-bottom: 40px; }
.sub-badge {
  font-size: 11px;
  letter-spacing: 1px;
  background: #f0f0f0;
  padding: 5px 15px;
  border-radius: 20px;
  color: #666;
}
.slider-title { font-size: 42px; color: #2d3e2d; margin-top: 15px; font-family: serif; }
.slider-title span { font-style: italic; color: #5c7c5c; font-weight: 400; }

.video-grid-container {
  padding: 0 20px;
  max-width: 1400px;
  margin: 0 auto;
}

.video-flex-wrapper {
  display: flex;
  gap: 15px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none; /* Hide scrollbar for clean look */
}
.video-flex-wrapper::-webkit-scrollbar { display: none; }

.video-card {
  flex: 0 0 calc(20% - 12px); /* 5 cards on desktop */
  scroll-snap-align: start;
  border: 1px solid #eee;
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
}

.video-element-wrapper {
  position: relative;
  aspect-ratio: 9/16;
  background: #000;
}
.card-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  cursor: pointer;
}

.video-actions {
  position: absolute;
  bottom: 15px;
  right: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.action-btn {
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
}

.video-card-info { padding: 15px; }
.author-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.author-thumb { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; }
.product-title { font-size: 13px; font-weight: 600; color: #333; }
.product-desc { font-size: 11px; color: #777; margin: 5px 0; line-height: 1.4; }
.product-price { display: block; font-weight: bold; margin-bottom: 12px; font-size: 14px; }

.add-to-cart-btn {
  width: 100%;
  background: #e1ede3;
  border: none;
  padding: 10px;
  border-radius: 6px;
  color: #3d5a3d;
  font-weight: 500;
  cursor: pointer;
  transition: 0.3s;
}
.add-to-cart-btn:hover { background: #d0e0d3; }

/* Mobile Slider adjustments */
@media (max-width: 1024px) {
  .video-card { flex: 0 0 45%; } /* 2.2 cards on tablet */
}
@media (max-width: 768px) {
  .video-card { flex: 0 0 75%; } /* 1.3 cards on mobile to show hint of next card */
  .slider-title { font-size: 28px; }
}
</style>

<script>

// 1. Heart Toggle Logic
function toggleHeart(button) {
  button.classList.toggle('is-active');
  
  // Optional: Add haptic feedback for mobile
  if (window.navigator.vibrate) {
    window.navigator.vibrate(10);
  }
}

// 2. Native Share Logic (WhatsApp, Facebook, etc.)
async function shareProduct(url, title) {
  const shareData = {
    title: title,
    text: 'Check out this ' + title,
    url: url
  };

  try {
    if (navigator.share) {
      // Opens native mobile share menu
      await navigator.share(shareData);
    } else {
      // Fallback for Desktop: Copy to clipboard
      await navigator.clipboard.writeText(url);
      alert('Link copied to clipboard!');
    }
  } catch (err) {
    console.log('Error sharing:', err);
  }
}

document.addEventListener('DOMContentLoaded', function() {
  const videoCards = document.querySelectorAll('.video-card');

  videoCards.forEach(card => {
    const video = card.querySelector('.card-video');

    // Desktop: Play on Hover
    card.addEventListener('mouseenter', () => {
      video.play();
    });

    card.addEventListener('mouseleave', () => {
      video.pause();
      video.currentTime = 0; // Optional: reset to thumbnail
    });

    // Mobile: Play when in view or on tap
    card.addEventListener('touchstart', () => {
      if (video.paused) {
        video.play();
      } else {
        video.pause();
      }
    });
  });
});
</script>
